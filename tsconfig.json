{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": ".",
    "outDir": "dist",
    "baseUrl": ".",

    "paths": {
      "@entry/*": ["entry/*"],
      "@app/*": ["app/*"],
      "@core/*": ["core/*"],
      "@domain/*": ["domain/*"]
    },

    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "entry/**/*.ts",
    "app/**/*.ts",
    "domain/**/*.ts",
    "core/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
